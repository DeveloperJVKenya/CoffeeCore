<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        REMOVED: READ_MEDIA_IMAGES, READ_EXTERNAL_STORAGE, WRITE_EXTERNAL_STORAGE
        ─────────────────────────────────────────────────────────────────────────
        Google Play's Photo & Video Permissions policy prohibits these permissions
        for apps that only need one-time / infrequent image access.
        image_picker uses the Android Photo Picker (ACTION_PICK_IMAGES) on
        Android 13+ and a file-intent fallback on older versions — neither path
        requires broad storage permissions when the picker is invoked correctly.

        CAMERA is kept because the app captures live photos for AI scanning.
    -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!--
        READ_MEDIA_VISUAL_USER_SELECTED  (Android 14+, API 34+)
        ─────────────────────────────────────────────────────────
        This is the ONLY media permission that is still allowed for apps whose
        core use case is one-time image selection.  It grants access only to the
        specific assets the user selects in the system picker — nothing more.
        Mark it maxSdkVersion="33" is NOT needed here; the OS ignores it on
        older devices.  Add it so Android 14 devices show a "Selected photos
        only" grant option instead of full library access.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <application
        android:label="CoffeeCore"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${mapsApiKey}" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>